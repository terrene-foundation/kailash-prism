{
  "name": "@kailash/prism-web",
  "version": "0.3.1",
  "description": "Kailash Prism web engine — React, Next.js, and Tauri components and engines",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.js",
    "./engines/*": "./dist/engines/*.js",
    "./atoms/*": "./dist/atoms/*.js",
    "./molecules/*": "./dist/molecules/*.js",
    "./organisms/*": "./dist/organisms/*.js",
    "./templates/*": "./dist/templates/*.js",
    "./hooks/*": "./dist/hooks/*.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src/"
  },
  "keywords": [
    "kailash",
    "prism",
    "react",
    "nextjs",
    "tauri",
    "design-system",
    "component-library"
  ],
  "author": "Terrene Foundation",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/terrene-foundation/kailash-prism.git",
    "directory": "web"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.0",
    "@tanstack/react-virtual": "^3.13.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^26.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
