{
  "name": "@kailash/prism-compiler",
  "version": "0.1.0",
  "description": "Kailash Prism token compiler — design specs to framework tokens",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "prism-compile": "dist/cli.js",
    "prism-scaffold": "dist/scaffold-cli.js",
    "prism-codegen": "dist/codegen/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "compile:web": "node dist/cli.js --theme enterprise --target web",
    "compile:flutter": "node dist/cli.js --theme enterprise --target flutter",
    "codegen": "node dist/codegen/cli.js --spec ../specs/components/data-table.yaml --out generated/data-table-adapter-spec.ts"
  },
  "keywords": [
    "kailash",
    "prism",
    "design-tokens",
    "compiler"
  ],
  "author": "Terrene Foundation",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/terrene-foundation/kailash-prism.git",
    "directory": "compiler"
  },
  "dependencies": {
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "vitest": "^3.1.0",
    "@types/node": "^22.15.0"
  }
}
